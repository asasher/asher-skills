+abort_run() {
+  local component="$1" status="$2" message="$3"
+  mark_run_error "$component" "$status" "$message"
+  echo "ERROR: $message" >&2
+  if [[ "$status" =~ ^[0-9]+$ && "$status" -gt 0 && "$status" -le 255 ]]; then
+    exit "$status"
+  fi
+  exit 1
+}
