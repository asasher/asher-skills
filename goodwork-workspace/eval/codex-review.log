    96	def strip_code_and_urls(text: str) -> str:
    97	    text = re.sub(r"```.*?```", "", text, flags=re.DOTALL)
    98	    text = re.sub(r"`[^`]*`", "", text)
    99	    text = re.sub(r"https?://\S+", "", text)
   100	    return text
