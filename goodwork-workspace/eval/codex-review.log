   221	    a = first.read_text(encoding="utf-8", errors="replace").splitlines()
   222	    b = second.read_text(encoding="utf-8", errors="replace").splitlines()
   223	    nonblank_a = [line.strip() for line in a if line.strip()]
   224	    nonblank_b = {line.strip() for line in b if line.strip()}
   225	    retained = sum(1 for line in nonblank_a if line in nonblank_b)
   226	    retention = retained / max(1, len(nonblank_a))
   227	    changed = a != b
