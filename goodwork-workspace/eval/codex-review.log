   202	def assert_cumulative_update(run_dir: Path, metadata: dict[str, Any], assertions: list[dict[str, Any]]) -> None:
   203	    sessions = int(metadata.get("sessions") or 1)
   204	    if sessions < 2:
   205	        add_skipped(assertions, "session2_cumulative_update", "Run is not marked multi-session.")
   206	        return
   207	
   208	    first = run_dir / "profile-session-1.md"
   209	    second = run_dir / "profile-session-2.md"
   210	    if not first.exists() or not second.exists():
   211	        add_assertion(
   212	            assertions,
   213	            "session2_cumulative_update",
   214	            False,
   215	            "Missing profile snapshot for session 1 or session 2.",
