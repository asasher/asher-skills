    79	def transcript_turns(transcript: str) -> list[dict[str, Any]]:
    80	    matches = list(TURN_RE.finditer(transcript))
    81	    turns: list[dict[str, Any]] = []
    82	    for idx, match in enumerate(matches):
    83	        start = match.end()
    84	        end = matches[idx + 1].start() if idx + 1 < len(matches) else len(transcript)
    85	        turns.append(
    86	            {
    87	                "role": match.group(1),
    88	                "session": int(match.group(2)),
    89	                "turn": int(match.group(3)),
    90	                "body": transcript[start:end].strip(),
    91	            }
    92	        )
    93	    return turns
