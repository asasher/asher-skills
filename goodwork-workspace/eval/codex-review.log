+        "error_component": component,
+        "error": message,
+        "summary": {"passed": 0, "failed": 0, "skipped": 0},
+        "assertions": [],
+    },
+    open(out, "w", encoding="utf-8"),
+    indent=2,
+)
+print()
+PY
+}
+
+abort_run() {
+  local component="$1" status="$2" message="$3"
+  mark_run_error "$component" "$status" "$message"
+  echo "ERROR: $message" >&2
