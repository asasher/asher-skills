+        "error_component": component,
+        "error": message,
+        "summary": {"passed": 0, "failed": 0, "skipped": 0},
+        "assertions": [],
+    },
+    open(out, "w", encoding="utf-8"),
+    indent=2,
+)
+print()
+PY
+}
