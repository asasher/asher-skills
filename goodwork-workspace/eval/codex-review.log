   159	
   160	def difficulty_summary(judge):
   161	    summary = judge.get("summary") or {}
   162	    by_diff = summary.get("recall_by_difficulty") or {}
   163	    if by_diff:
   164	        return {
   165	            key: pct((val or {}).get("recall")) if isinstance(val, dict) else "n/a"
