   107	def assert_one_question(turns: list[dict[str, Any]], assertions: list[dict[str, Any]]) -> None:
   108	    failures = []
   109	    checked = 0
   110	    for turn in turns:
   111	        if turn["role"] != "Subject":
   112	            continue
   113	        body = turn["body"]
   114	        if "[[GOODWORK_DONE]]" in body:
   115	            continue
   116	        checked += 1
   117	        count = question_count(body)
