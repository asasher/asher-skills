   119	            failures.append(
   120	                {
   121	                    "session": turn["session"],
   122	                    "turn": turn["turn"],
   123	                    "question_count": count,
   124	                    "excerpt": body[:500],
   125	                }
   126	            )
   127	    add_assertion(
   128	        assertions,
   129	        "one_question_per_subject_turn",
   130	        checked > 0 and not failures,
   131	        f"Checked {checked} non-final subject turns; {len(failures)} failed.",
   132	        failures=failures,
   133	    )
