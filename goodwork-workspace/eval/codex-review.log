   350	raw_path, text_path, session_path = map(Path, sys.argv[1:])
   351	raw = raw_path.read_text(encoding="utf-8", errors="replace")
   352	result = raw
   353	session_id = ""
   354	try:
   355	    data = json.loads(raw)
   356	    session_id = str(data.get("session_id") or "")
   357	    for key in ("result", "response", "message", "content", "text"):
   358	        if key in data and data[key]:
   359	            result = data[key]
   360	            break
   361	    if isinstance(result, list):
   362	        result = "\n".join(str(x.get("text", x)) if isinstance(x, dict) else str(x) for x in result)
   363	    elif isinstance(result, dict):
   364	        result = json.dumps(result, indent=2)
   365	except Exception:
   366	    pass
   367	text_path.write_text(str(result).strip() + "\n", encoding="utf-8")
   368	if session_id:
   369	    session_path.write_text(session_id + "\n", encoding="utf-8")
   370	PY
   371	}
