  "weeks": [
    {
      "week_start": "date",
      "outreach_sent": "number",
      "applications": "number",
      "screens": "number",
      "interviews": "number",
      "offers": "number",
      "response_rate": "number | null",
      "notes": "string | null"
    }
  ],
  "evidence_inbox": [
    {
      "id": "ev_*",
      "event_id": "evt_*",
      "source": "lead|pipeline|approval|reply|journal|prototype",
      "profile_sections": ["string"],
      "claim": "string",
      "status": "pending|drained|dismissed",
      "created_at": "datetime",
      "drained_at": "datetime | null"
    }
  ]
}
```

Example record:

```json
