      "source": "lead|pipeline|approval|reply|journal|prototype|review",
      "source_id": "string | null",
      "profile_sections": ["string"],
      "claim": "string",
      "status": "pending|drained|dismissed",
      "created_at": "datetime",
      "drained_at": "datetime | null"
    }
  ]
}
```

