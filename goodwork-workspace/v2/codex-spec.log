+
+## `leads.json`
+
+Schema:
+
+```json
+{
+  "version": "number",
+  "updated_at": "datetime",
+  "leads": [
+    {
+      "id": "lead_*",
+      "source_id": "src_*",
+      "target_id": "tgt_* | null",
+      "title": "string",
+      "org": "string",
+      "url": "url",
+      "location": "string | null",
+      "posted_at": "date | null",
+      "found_at": "datetime",
+      "score": "number",
+      "status": "bench|queued|dismissed|promoted|applied|stale",
+      "score_reasons": ["string"],
+      "must_haves": ["string"],
+      "evidence_coverage": "number | null",
+      "pipeline_id": "pipe_* | null"
+    }
+  ]
+}
+```
+
+Example record:
+
+```json
