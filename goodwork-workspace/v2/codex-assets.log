   194	            "leads": leads,
   195	            "targets": targets,
   196	        }
   197	
   198	    def serve_static(self, raw_name: str):
   199	        name = unquote(raw_name).lstrip("/")
   200	        roots = [self.app["workspace"] / "vendor", self.app["workspace"] / "static"]
   201	        for root in roots:
   202	            path = (root / name).resolve()
   203	            if root.resolve() in path.parents and path.is_file():
   204	                data = path.read_bytes()
   205	                ctype = mimetypes.guess_type(path.name)[0] or "application/octet-stream"
   206	                self._send(HTTPStatus.OK, data, ctype)
   207	                return
   208	        self._send(HTTPStatus.NOT_FOUND, b"not found", "text/plain; charset=utf-8")
   209	
   210	
   211	def collect_items(pipeline: dict, leads: dict, targets: dict) -> list[dict]:
   212	    by_target = {t.get("id"): t for t in targets.get("targets", []) if isinstance(t, dict)}
   213	    items: list[dict] = []
   214	    for card in pipeline.get("cards", []):
   215	        if not isinstance(card, dict) or card.get("status") == "closed":
   216	            continue
   217	        drafts = {d.get("artifact_id"): d for d in card.get("drafts", []) if isinstance(d, dict)}
   218	        for artifact_id in card.get("artifact_ids", []) or []:
   219	            draft = drafts.get(artifact_id, {})
   220	            target = by_target.get(card.get("target_id"), {})
   221	            items.append({
   222	                "id": artifact_id,
   223	                "title": card.get("role") or target.get("name") or artifact_id,
   224	                "card_id": card.get("id"),
   225	                "channel": draft.get("channel") or "manual",
   226	                "destination": target.get("name") or card.get("lead_id") or "manual",
   227	                "content_hash": draft.get("content_hash"),
   228	                "next_action": card.get("next_action"),
   229	            })
   230	    for lead in leads.get("leads", []):
   231	        if isinstance(lead, dict) and lead.get("status") in {"queued", "bench", "promoted"}:
   232	            items.append({
   233	                "id": lead.get("id"),
   234	                "title": f"{lead.get('title', 'Lead')} at {lead.get('org', '')}".strip(),
   235	                "channel": "manual",
   236	                "destination": lead.get("url"),
   237	                "content_hash": lead.get("content_hash"),
   238	                "next_action": lead.get("status"),
   239	            })
   240	    return items
   241	
   242	
   243	def has_pending(workspace: Path) -> bool:
   244	    pipeline = load_json(workspace / "pipeline.json", {"cards": []})
   245	    return bool(collect_items(pipeline, {"leads": []}, {"targets": []}))
   246	
   247	
   248	def main() -> int:
   249	    parser = argparse.ArgumentParser()
   250	    parser.add_argument("--workspace", default="goodwork")
   251	    parser.add_argument("--idle-timeout", type=float, default=30.0)
   252	    args = parser.parse_args()
   253	    workspace = Path(args.workspace).resolve()
   254	    token = secrets.token_urlsafe(24)
   255	    session_id = "sess_" + datetime.now().strftime("%Y%m%d_") + secrets.token_hex(2)
   256	    server = HTTPServer(("127.0.0.1", 0), GoodworkHandler)
   257	    server.timeout = 0.5
   258	    server.app = {"workspace": workspace, "token": token, "session_id": session_id, "last_activity": time.monotonic()}
   259	    port = server.server_address[1]
   260	    print(json.dumps({"host": "127.0.0.1", "port": port, "token": token, "session_id": session_id}), flush=True)
   261	    try:
   262	        while True:
   263	            server.handle_request()
   264	            idle = time.monotonic() - server.app["last_activity"]
   265	            if idle >= args.idle_timeout and not has_pending(workspace):
   266	                break
   267	    finally:
   268	        server.server_close()
   269	    return 0
   270	
   271	
   272	if __name__ == "__main__":
   273	    raise SystemExit(main())

