{
  "id": "sdlc",
  "title": "The SDLC skill family",
  "subtitle": "Groom fans shaping threads; the user crystallises spec \u2192 tickets; build fans worktree subagents to review-ready change requests; a human merges \u2014 every node renders its real files, live from this repo.",
  "lanes": [
    {
      "id": "dispatch",
      "title": "Dispatch",
      "blurb": "The dispatcher and the machinery it fans out with: attachable threads, staffed subagents, watchers."
    },
    {
      "id": "shaping",
      "title": "Shaping",
      "blurb": "Settle one subject's strategic decisions in an interactive thread; probe when paper can't settle it."
    },
    {
      "id": "crystallise",
      "title": "Crystallise",
      "blurb": "The user's call after shaping: write the spec, split it into tracker-native tickets."
    },
    {
      "id": "build",
      "title": "Build",
      "blurb": "One ready ticket through implement \u2192 verify to a review-ready change request."
    },
    {
      "id": "review",
      "title": "Review & ship",
      "blurb": "Adversarial review converges to LGTM, evidence lands on the change request, a human authorizes the merge."
    },
    {
      "id": "services",
      "title": "Services",
      "blurb": "Cross-cutting: the tailnet review surface, session handoff, and the model roster."
    }
  ],
