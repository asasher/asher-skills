    {
      "id": "shaping",
      "title": "Shaping",
      "blurb": "Elicit and settle the strategic decisions; write the useful shape down as it crystallises."
    },
    {
      "id": "formation",
      "title": "Formation",
      "blurb": "Turn the settled direction into a gated spec and audited, tracker-native tickets."
    },
    {
      "id": "execution",
      "title": "Execution",
      "blurb": "The backlog drains admitted work through the build loop to review-ready PRs; a human merges."
    },
    {
