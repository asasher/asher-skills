      "id": "surface",
      "title": "Command surface",
      "blurb": "A thin head: fan tickets into threads, report how to attach — no result flows back."
    },
    {
      "id": "groom",
      "title": "groom = shaping fan-out",
      "blurb": "Sweep unlabeled + needs-shaping tickets, route the settled and parked, group into subjects and batches, confirm the plan with the user — then one thread per batch."
    },
    {
      "id": "buildout",
      "title": "build = build fan-out",
      "blurb": "Sweep ready tickets with clear edges, mark building, dispatch one worktree-isolated build subagent each and supervise it."
    },
    {
      "id": "siblings",
      "title": "Composed siblings (by name)",
      "blurb": "Named runtime pointers, never file imports — jump to the family view."
    },
    {
