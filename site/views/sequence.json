{
  "id": "sequence",
  "title": "Sequence",
  "subtitle": "The end-to-end conversation over time: who talks to whom \u2014 the user, the dispatcher, attachable shaping threads, supervised build subagents, their nested workers, and the tracker.",
  "type": "sequence",
  "actors": [
    {
      "id": "user",
      "title": "User \u270b",
      "blurb": "asks, attends, decides",
      "kind": "you"
    },
    {
      "id": "backlog",
      "title": "backlog",
      "blurb": "dispatcher",
      "kind": "disp"
    },
    {
      "id": "thread",
      "title": "Shaping thread",
      "blurb": "to-thread \u00b7 shape",
      "kind": "thread"
    },
    {
      "id": "builder",
      "title": "Build subagent",
      "blurb": "to-subagent \u00b7 build \u00b7 worktree",
      "kind": "sub"
    },
    {
      "id": "workers",
      "title": "Nested workers",
      "blurb": "implement \u00b7 verify \u00b7 review \u00b7 evidence",
      "kind": "sub"
    },
    {
      "id": "tracker",
      "title": "Tracker & repo",
      "blurb": "tickets \u00b7 labels \u00b7 change requests",
      "kind": "repo"
    }
  ],
  "messages": [
    {
      "phase": "Groom \u2014 interactive, nothing flows back"
    },
    {
      "from": "user",
      "to": "backlog",
      "label": "backlog groom",
      "style": "flow"
    },
    {
      "from": "backlog",
      "to": "tracker",
      "label": "sweep needs-shaping \u00b7 mark shaping",
      "style": "flow"
    },
    {
      "from": "backlog",
      "to": "thread",
      "label": "spawn via to-thread \u2014 named, seeded",
      "style": "flow"
    },
    {
      "from": "backlog",
      "to": "user",
      "label": "attach instructions",
      "style": "return"
    },
    {
      "from": "user",
      "to": "thread",
      "label": "attend: interview rounds",
      "style": "bidir"
    },
    {
      "from": "thread",
      "to": "workers",
      "label": "research \u00b7 prototype via to-subagent",
      "style": "flow"
    },
    {
      "from": "workers",
      "to": "thread",
      "label": "findings wake the thread",
      "style": "return"
    },
    {
      "from": "thread",
      "to": "tracker",
      "label": "decisions on the ticket \u00b7 CONTEXT.md \u00b7 ADRs",
      "style": "flow"
    },
    {
      "from": "user",
      "to": "thread",
      "label": "your call: to-spec / to-tickets",
      "style": "flow"
    },
    {
      "from": "thread",
      "to": "tracker",
      "label": "to-spec / to-tickets: spec + born-shaped tickets published",
      "style": "flow"
    },
    {
      "from": "user",
      "to": "tracker",
      "label": "AFK: comments on the published tickets",
      "style": "flow"
    },
    {
      "from": "thread",
      "to": "tracker",
      "label": "watch-until: apply tweaks \u00b7 reply \u21bb",
      "style": "bidir"
    },
    {
      "from": "user",
      "to": "thread",
      "label": "LGTM \u2014 ready for agent",
      "style": "flow"
    },
    {
      "from": "thread",
      "to": "tracker",
      "label": "readiness applied \u2014 the user's call, executed",
      "style": "flow"
    },
    {
      "phase": "Build \u2014 autonomous, supervised"
    },
    {
      "from": "user",
      "to": "backlog",
      "label": "backlog build",
      "style": "flow"
    },
    {
      "from": "backlog",
      "to": "tracker",
      "label": "sweep ready + unblocked \u00b7 mark building",
      "style": "flow"
    },
    {
      "from": "backlog",
      "to": "builder",
      "label": "dispatch via to-subagent \u2014 own worktree",
      "style": "flow"
    },
    {
      "from": "builder",
      "to": "workers",
      "label": "implement (tdd / diagnosing-bugs)",
      "style": "flow"
    },
    {
      "from": "builder",
      "to": "workers",
      "label": "verify-your-work \u2014 findings back, builder fixes \u21bb",
      "style": "bidir"
    },
    {
      "from": "builder",
      "to": "tracker",
      "label": "open change request \u2014 Closes #N",
      "style": "flow"
    },
    {
      "from": "builder",
      "to": "workers",
      "label": "adversarial review: reviewer \u21c6 fixer until LGTM",
      "style": "bidir"
    },
    {
      "from": "builder",
      "to": "tracker",
      "label": "evidence posted (prove-your-work)",
      "style": "flow"
    },
    {
      "from": "builder",
      "to": "backlog",
      "label": "wake: review-ready change request",
      "style": "return"
    },
    {
      "from": "backlog",
      "to": "user",
      "label": "outcomes relayed",
      "style": "return"
    },
    {
      "phase": "Merge \u2014 explicit human authorization"
    },
    {
      "from": "user",
      "to": "tracker",
      "label": "authorize merge (merge-changes) \u2192 ticket closes",
      "style": "flow"
    }
  ]
}
