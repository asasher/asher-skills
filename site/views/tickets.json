      "labelAt": 0.5
    },
    {
      "from": "t-born",
      "to": "t-ready",
      "style": "flow",
      "label": "comment watch → readiness blessed"
    },
    {
      "from": "t-ready",
      "to": "t-building",
      "style": "flow",
      "label": "build dispatches (edges clear)"
    },
    {
      "from": "t-building",
      "to": "t-closed",
      "style": "flow",
      "label": "merged — Closes #N"
    },
    {
      "from": "t-building",
