    },
    {
      "from": "t-built",
      "to": "t-closed",
      "style": "external",
      "label": "promotion merge"
    },
    {
      "from": "t-new",
      "to": "t-info",
      "style": "optional",
      "label": "waiting on reporter",
      "labelAt": 0.7
    },
    {
      "from": "t-building",
      "to": "t-human",
      "style": "optional",
      "label": "blocker handback",
      "labelAt": 0.6
    },
    {
      "from": "t-shaping",
