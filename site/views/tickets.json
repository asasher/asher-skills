{
  "id": "tickets",
  "title": "Ticket states",
  "subtitle": "The ticket lifecycle: label roles from backlog-policy.md \u2014 needs-shaping \u2192 shaping \u2192 ready-for-agent \u2192 building \u2192 closed by merge, with parked states and the repo-bound staging override.",
  "type": "swimlane",
  "lanes": [
    {
      "id": "default",
      "title": "Shipped default",
      "blurb": "four label roles plus tracker-native closure"
    },
    {
      "id": "override",
      "title": "Repo overrides",
      "blurb": "bound per repo in backlog-policy.md \u2014 not shipped"
    },
    {
      "id": "parked",
      "title": "Parked & excluded",
      "blurb": "outside the pickup loop"
    }
  ],
  "phases": [
    {
      "id": "triage",
      "title": "Triage"
    },
    {
      "id": "shape",
      "title": "Shape"
    },
    {
      "id": "ready",
      "title": "Ready"
    },
    {
      "id": "build",
      "title": "Build"
    },
    {
      "id": "done",
      "title": "Done"
    }
  ],
  "nodes": [
    {
      "id": "t-new",
      "lane": "default",
      "phase": "triage",
      "title": "(no readiness label)",
      "blurb": "not yet groomed \u2014 a target for backlog groom"
    },
    {
      "id": "t-needs",
      "lane": "default",
      "phase": "triage",
      "title": "needs-shaping",
      "blurb": "strategic decisions unsettled \u2014 groom's route judgment, or a build handback"
    },
    {
      "id": "t-shaping",
      "lane": "default",
      "phase": "shape",
      "title": "shaping",
      "blurb": "a shaping thread is attending it \u2014 set by groom at dispatch"
    },
    {
      "id": "t-born",
      "lane": "default",
      "phase": "shape",
      "title": "born shaped",
      "blurb": "created by an approved to-tickets split \u2014 tweaked via the thread's comment watch, never re-shaped",
      "dashed": true
    },
    {
      "id": "t-ready",
      "lane": "default",
      "phase": "ready",
      "title": "ready-for-agent",
      "blurb": "blessed for pickup \u2014 a human readiness decision; work-type + dispatch metadata required"
    },
    {
      "id": "t-building",
      "lane": "default",
      "phase": "build",
      "title": "building",
      "blurb": "a build subagent owns it \u2014 set by backlog build, replacing ready-for-agent"
    },
    {
      "id": "t-closed",
      "lane": "default",
      "phase": "done",
      "title": "closed",
      "blurb": "tracker-native \u2014 the change request's Closes #N lands on merge; no label"
    },
    {
      "id": "t-built",
      "lane": "override",
      "phase": "done",
      "title": "built (example)",
      "blurb": "merged to staging; closure deferred to the promotion merge",
