{
  "id": "tickets",
  "title": "Ticket states",
  "subtitle": "The ticket lifecycle: label roles from backlog-policy.md — needs-shaping → shaping → ready-for-agent → building → closed by merge, with parked states and the repo-bound staging override.",
  "type": "swimlane",
  "lanes": [
    {
      "id": "default",
      "title": "Shipped default",
      "blurb": "four label roles plus tracker-native closure"
    },
    {
      "id": "override",
      "title": "Repo overrides",
      "blurb": "bound per repo in backlog-policy.md — not shipped"
    },
    {
      "id": "parked",
      "title": "Parked & excluded",
      "blurb": "outside the pickup loop"
    }
  ],
  "phases": [
    {
      "id": "triage",
      "title": "Triage"
    },
    {
      "id": "shape",
      "title": "Shape"
    },
    {
      "id": "ready",
      "title": "Ready"
    },
    {
      "id": "build",
      "title": "Build"
    },
    {
      "id": "done",
      "title": "Done"
    }
  ],
  "nodes": [
    {
      "id": "t-new",
      "lane": "default",
      "phase": "triage",
      "title": "(no readiness label)",
      "blurb": "unlabeled — swept and routed by backlog groom"
    },
    {
      "id": "t-needs",
      "lane": "default",
      "phase": "triage",
      "title": "needs-shaping",
      "blurb": "strategic decisions unsettled — groom's route judgment, or a build handback"
    },
    {
      "id": "t-shaping",
      "lane": "default",
      "phase": "shape",
      "title": "shaping",
      "blurb": "a shaping thread is attending it — set by groom at dispatch, after the batch plan is confirmed"
    },
    {
      "id": "t-born",
      "lane": "default",
      "phase": "shape",
      "title": "born shaped",
      "blurb": "created by an approved to-tickets split — tweaked via the thread's comment watch, never re-shaped",
      "dashed": true
    },
    {
      "id": "t-ready",
      "lane": "default",
      "phase": "ready",
      "title": "ready-for-agent",
      "blurb": "blessed for pickup — a human readiness decision; work-type + dispatch metadata required"
    },
    {
      "id": "t-building",
      "lane": "default",
      "phase": "build",
      "title": "building",
      "blurb": "a build subagent owns it — set by backlog build, replacing ready-for-agent"
    },
    {
      "id": "t-closed",
      "lane": "default",
      "phase": "done",
      "title": "closed",
      "blurb": "tracker-native — the change request's Closes #N lands on merge; no label"
    },
    {
      "id": "t-built",
      "lane": "override",
      "phase": "done",
      "title": "built (example)",
      "blurb": "merged to staging; closure deferred to the promotion merge",
      "dashed": true
    },
    {
      "id": "t-info",
      "lane": "parked",
      "phase": "triage",
      "title": "needs-info",
      "blurb": "the reporter owes facts"
    },
    {
      "id": "t-human",
      "lane": "parked",
      "phase": "ready",
      "title": "ready-for-human",
      "blurb": "human-only; also the abort target for blockers"
    },
    {
      "id": "t-excl",
      "lane": "parked",
      "phase": "done",
      "title": "excluded",
      "blurb": "wontfix · duplicate · superseded · invalid"
    }
  ],
  "edges": [
    {
      "from": "t-new",
      "to": "t-needs",
      "style": "flow",
      "label": "groom routes"
    },
    {
