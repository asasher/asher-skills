    },
    {
      "id": "t-info",
      "lane": "parked",
      "phase": "triage",
      "title": "needs-info",
      "blurb": "the reporter owes facts"
    },
    {
      "id": "t-human",
      "lane": "parked",
      "phase": "ready",
      "title": "ready-for-human",
      "blurb": "human-only; also the abort target for blockers"
    },
    {
      "id": "t-excl",
      "lane": "parked",
      "phase": "done",
      "title": "excluded",
      "blurb": "wontfix \u00b7 duplicate \u00b7 superseded \u00b7 invalid"
