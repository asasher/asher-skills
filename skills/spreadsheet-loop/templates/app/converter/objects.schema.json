{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "objects.schema.json",
  "title": "Spreadsheet Loop declared objects",
  "type": "object",
  "required": ["charts", "pivots"],
  "additionalProperties": false,
  "properties": {
    "charts": {
      "type": "array",
      "uniqueItems": true,
      "x-uniqueBy": "id",
      "items": {
        "type": "object",
        "required": ["id", "sheet", "type", "categories", "values", "anchor"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "sheet": { "type": "string" },
          "sheetId": { "type": "string" },
          "type": { "type": "string", "enum": ["bar", "line", "pie"] },
          "title": { "type": "string" },
          "categories": {
            "type": "string",
            "pattern": "^(?:(?:'(?:[^']|'')+'|[^'!]+)!)?\\$?[A-Za-z]{1,3}\\$?[1-9][0-9]*(?::\\$?[A-Za-z]{1,3}\\$?[1-9][0-9]*)?$"
          },
          "values": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^(?:(?:'(?:[^']|'')+'|[^'!]+)!)?\\$?[A-Za-z]{1,3}\\$?[1-9][0-9]*(?::\\$?[A-Za-z]{1,3}\\$?[1-9][0-9]*)?$"
            }
          },
          "seriesTitles": {
            "type": "array",
            "items": { "type": "string" }
          },
          "anchor": {
            "type": "string",
            "pattern": "^\\$?[A-Za-z]{1,3}\\$?[1-9][0-9]*$"
          }
        }
      }
    },
    "pivots": {
      "type": "array",
      "uniqueItems": true,
      "x-uniqueBy": "id",
      "items": {
        "type": "object",
        "required": ["id", "sheet", "source", "rows", "values", "anchor"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "sheet": { "type": "string" },
          "sheetId": { "type": "string" },
          "source": {
            "type": "string",
            "pattern": "^(?:(?:'(?:[^']|'')+'|[^'!]+)!)?\\$?[A-Za-z]{1,3}\\$?[1-9][0-9]*(?::\\$?[A-Za-z]{1,3}\\$?[1-9][0-9]*)?$"
          },
          "rows": {
            "type": "array",
            "items": { "type": "string" }
          },
          "cols": {
            "type": "array",
            "items": { "type": "string" }
          },
          "values": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["field", "agg"],
              "additionalProperties": false,
              "properties": {
                "field": { "type": "string" },
                "agg": { "type": "string", "enum": ["sum", "count", "avg", "min", "max"] }
              }
            }
          },
          "anchor": {
            "type": "string",
            "pattern": "^\\$?[A-Za-z]{1,3}\\$?[1-9][0-9]*$"
          }
        }
      }
    },
    "_import_note": { "type": "string" }
  }
}
