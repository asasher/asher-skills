+  Q --> B["control dynamics?"]
+  Q --> C["body/learning mechanism?"]
+  Q --> D["intervention results?"]
+  Q --> E["agency remains?"]
+  Q --> F["extra essence?"]
+  Q --> G["policy/value choice?"]
+  A --> A1["repeated harm?"]
+  A --> A2["violated intentions?"]
+  B --> B1["craving/withdrawal?"]
+  B --> B2["ordinary incentives fail?"]
+  F --> F1["same observations?"]
+  G --> G1["what response helps?"]
 </pre>
     <!-- /FILL: trace -->
   </section>
 
